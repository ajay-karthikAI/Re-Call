# Runtime mode. Local development can omit this; production deploys must set production.
APP_ENV=development

APP_NAME="Re: Call"
API_PREFIX=/api
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Optional local API bearer token. Leave blank to disable auth in development.
# Production APP_ENV=production requires a non-empty token of at least 24 characters.
RECALL_API_TOKEN=

# macOS desktop overlay captures mic + system audio by default.
# Set to false to force microphone-only recording.
RECALL_ENABLE_SYSTEM_AUDIO=

# Frontend-only values used by Vite. Electron gets its runtime backend from RECALL_API_BASE_URL.
VITE_APP_ENV=development
VITE_API_BASE_URL=http://127.0.0.1:8000
# Only needed when the Vite web UI talks to a backend with RECALL_API_TOKEN set.
VITE_RECALL_API_TOKEN=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

DATABASE_URL=postgresql+asyncpg://recall:recall@localhost:5433/recall
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage:
# - Local development: leave S3_BUCKET_NAME blank to use LOCAL_STORAGE_DIR.
# - Production/cloud: set S3_BUCKET_NAME and AWS_REGION, then provide AWS credentials
#   through secrets or leave the key fields blank when using an instance/task role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
LOCAL_STORAGE_DIR=./storage

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_OAUTH_SCOPES=cloud_recording:read:list_recording_files cloud_recording:read:meeting_recording cloud_recording:read:meeting_transcript

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/meetings.space.readonly

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_OAUTH_SCOPES=offline_access User.Read OnlineMeetings.Read OnlineMeetingTranscript.Read.All

RUN_MIGRATIONS_ON_STARTUP=false

# Docker Compose app services only. Local dev can leave these unchanged.
API_PORT=8000
POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=
DOCKER_DATABASE_URL=
DOCKER_REDIS_URL=
DOCKER_CELERY_BROKER_URL=
DOCKER_CELERY_RESULT_BACKEND=
CELERY_WORKER_CONCURRENCY=2

# Production placeholders, for reference only. Do not commit real secrets.
# APP_ENV=production
# BACKEND_PUBLIC_URL=https://api.your-domain.example
# FRONTEND_ORIGIN=https://app.your-domain.example
# RECALL_API_TOKEN=replace-with-a-long-random-token
# VITE_APP_ENV=production
# VITE_API_BASE_URL=https://api.your-domain.example
# VITE_RECALL_API_TOKEN=replace-with-the-same-token-if-building-the-web-ui
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db.your-domain.example:5432/recall
# REDIS_URL=rediss://:PASSWORD@redis.your-domain.example:6379/0
# CELERY_BROKER_URL=rediss://:PASSWORD@redis.your-domain.example:6379/0
# CELERY_RESULT_BACKEND=rediss://:PASSWORD@redis.your-domain.example:6379/0
# OPENAI_API_KEY=sk-...
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=your-production-bucket
